# Required for Claude-powered analysis.
OPENAI_API_KEY=

# Optional: use Anthropic as a backup provider.
ANTHROPIC_API_KEY=

# Optional: override the default models in config/sources.yml.
OPENAI_MODEL=gpt-5.5
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: only needed when you enable the x-ai-search source.
TWITTERAPI_KEY=
